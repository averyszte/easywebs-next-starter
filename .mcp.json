{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"],
      "env": {
        "NODE_OPTIONS": "--use-system-ca"
      }
    },
    "magicuidesign-mcp": {
      "command": "npx",
      "args": ["-y", "@magicuidesign/mcp@latest"],
      "env": {
        "NODE_OPTIONS": "--use-system-ca"
      }
    },
    "@21st-dev/magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "NODE_OPTIONS": "--use-system-ca",
        "API_KEY": "${TWENTY_FIRST_DEV_API_KEY}"
      }
    }
  }
}