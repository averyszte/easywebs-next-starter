# Copy to .env.local and fill in. .env* is gitignored. In production, set these in
# the Vercel dashboard. Until these are set the app runs in DEMO mode (example data,
# no auth), so it builds and runs out of the box.

# --- Supabase --- https://supabase.com  (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefix with NEXT_PUBLIC_. Bypasses RLS; used for webhooks /
# admin jobs and by the Astro site's Cloudflare edge function (set there, not here).
SUPABASE_SERVICE_ROLE_KEY=
